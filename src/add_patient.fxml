<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import java.lang.classfile.Label?>
<?import java.awt.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <Label text="Add New Patient" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
        </Label>
    </top>

    <center>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="Patient ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField promptText="e.g. 1001" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="First Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Last Name:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Gender:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <ChoiceBox GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Date of Birth:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField promptText="mm/dd/yyyy" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Primary Physician:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <ComboBox prefWidth="220" promptText="Lastname, Firstname" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <HBox spacing="10" GridPane.rowIndex="6" GridPane.columnIndex="1">
                <Button text="Save Patient"/>
                <Button text="Cancel"/>
            </HBox>
        </GridPane>
    </center>
</BorderPane>
