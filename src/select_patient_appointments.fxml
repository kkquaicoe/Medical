<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <Label text="Patient Appointments" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
        </Label>
    </top>

    <center>
        <VBox spacing="10" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <GridPane hgap="10" vgap="10">
                <Label text="Select Patient:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox prefWidth="280" promptText="Choose a patient..." GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Appointments:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ListView prefWidth="280" prefHeight="220" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="View Details"/>
                <Button text="Close"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
