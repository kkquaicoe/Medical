<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <Label text="Add New Appointment" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
        </Label>
    </top>

    <center>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <Label text="Patient ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <Label text="Appointment Date:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField promptText="mm/dd/yyyy" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <Label text="Physician:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <ComboBox prefWidth="220" promptText="Lastname, Firstname" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <Label text="Height (in):" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <Label text="Weight (lb):" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <Label text="Temperature:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <Label text="Pulse:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <Label text="BP Systolic:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <Label text="BP Diastolic:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <TextField GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            <Label text="Notes:" GridPane.rowIndex="9" GridPane.columnIndex="0"/>
            <TextArea prefRowCount="3" GridPane.rowIndex="9" GridPane.columnIndex="1"/>

            <HBox spacing="10" GridPane.rowIndex="10" GridPane.columnIndex="1">
                <Button text="Save Appointment"/>
                <Button text="Cancel"/>
            </HBox>
        </GridPane>
    </center>
</BorderPane>
